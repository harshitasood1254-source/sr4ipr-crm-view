# SR4IPR CRM — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# PostgreSQL connection string
# Local development:
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/sr4ipr_crm
# Railway (replace with your Railway PostgreSQL URL):
# DATABASE_URL=postgresql://postgres:xxxx@containers-us-west-xxx.railway.app:5432/railway

# JWT Secret — use any long random string (minimum 32 characters)
# Generate one at: https://www.uuidgenerator.net/ (use two UUIDs joined together)
JWT_SECRET=replace-this-with-a-long-random-secret-string-minimum-32-chars

# Server port (Railway sets this automatically, keep 3000 for local dev)
PORT=3000

# Environment
NODE_ENV=production
